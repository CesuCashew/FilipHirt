# Neon Database Connection String
# Get from: https://console.neon.tech -> Your Project -> Connection Details
# (na Netlify ji vyplní Neon integrace automaticky; lokálně nastav ručně)
NETLIFY_DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Gmail SMTP
# App password: https://myaccount.google.com/apppasswords (requires 2-step verification)
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Your Email (where notifications will be sent; defaults to GMAIL_USER)
RECIPIENT_EMAIL=your.email@gmail.com
